generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  sku         String?
  description String
  price       Int
  images      String[]
  categoryId  String?
  tags        String[]
  inventory   Int       @default(0)
  weight      Float?
  length      Float?
  width       Float?
  height      Float?
  storeId     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  store       Store       @relation(fields: [storeId], references: [id])
  categoryRel Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  cartItems   CartItem[]
  orderItems  OrderItem[]
  imageRecords Image[]
}

model Category {
  id        String    @id @default(cuid())
  name      String
  storeId   String
  store     Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([name, storeId])
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String?
  passwordHash String?
  role         Role       @default(CUSTOMER)
  plan         StorePlan  @default(FREE)
  createdAt    DateTime   @default(now())

  stores        UserStore[]
  storeRequests StoreRequest[]
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  cartItems     CartItem[]
  auditLogs     AuditLog[]
}

enum Role {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
}

model Store {
  id                        String             @id @default(cuid())
  name                      String
  slug                      String             @unique
  domain                    String?            @unique
  plan                      StorePlan          @default(FREE)
  isActive                  Boolean            @default(true)
  storefrontType            StorefrontType     @default(DEFAULT)
  deploymentUrl             String?
  deploymentToken           String?
  deploymentStatus          String?
  createdAt                 DateTime           @default(now())

  products      Product[]
  categories    Category[]
  orders        Order[]
  settings      Setting[]
  users         UserStore[]
  storeRequests StoreRequest[]
  pages         Page[]
}

model UserStore {
  userId  String
  storeId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CartItem {
  id        String  @id @default(cuid())
  userId    String
  productId String
  quantity  Int     @default(1)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Order {
  id                    String      @id @default(cuid())
  userId                String
  storeId               String
  total                 Int
  status                OrderStatus @default(PENDING)
  stripePaymentIntentId  String?    @unique
  stripeCheckoutSessionId String?   @unique
  shippingName          String?
  shippingPhone         String?
  shippingAddress       String?
  shippingCity          String?
  shippingState         String?
  shippingZip           String?
  shippingCountry       String?
  createdAt             DateTime    @default(now())

  trackingCode          String?
  shippingLabelB64      String?
  shippingLabelUrl      String?
  shippingProduct       String?
  carrier               String?
  serviceLevel          String?
  shippingPrice         Int?
  easyshipShipmentId    String?
  shippingWeight        Float?
  shippingLength        Int?
  shippingWidth         Int?
  shippingHeight        Int?

  user   User         @relation(fields: [userId], references: [id])
  store  Store        @relation(fields: [storeId], references: [id])
  items  OrderItem[]
  events OrderEvent[]
}

model OrderEvent {
  id        String   @id @default(cuid())
  orderId   String
  fromStatus String?
  toStatus  String
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

model Setting {
  storeId String
  key     String
  value   String

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, key])
}

model PlatformSetting {
  key   String @id
  value String
}

model Image {
  id        String   @id @default(cuid())
  productId String?
  publicId  String   @unique
  url       String
  width     Int?
  height    Int?
  format    String?
  bytes     Int?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([productId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model Page {
  id        String   @id @default(cuid())
  storeId   String
  slug      String
  title     String
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, slug])
}

model StoreRequest {
  id                        String             @id @default(cuid())
  storeName                 String
  adminId                   String
  admin                     User               @relation(fields: [adminId], references: [id])
  status                    StoreRequestStatus @default(PENDING)
  storefrontType            StorefrontType     @default(DEFAULT)
  enableToken               Boolean            @default(false)
  customizationData         Json?              // { domain?, primaryColor?, secondaryColor?, logoUrl?, faviconUrl?, fontFamily? }
  adminNotes                String?
  rejectReason              String?
  storeId                   String?
  store                     Store?             @relation(fields: [storeId], references: [id], onDelete: SetNull)
  setupFeePaid              Boolean            @default(false)
  setupFeePaymentIntentId   String?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt
}

enum StoreRequestStatus {
  PENDING
  APPROVED
  APPROVED_PENDING_PAYMENT
  REJECTED
}

enum StorePlan {
  FREE
  MONTHLY
  CUSTOM
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String
  entityId   String?
  details    Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

enum StorefrontType {
  DEFAULT
  INDEPENDENT
}
